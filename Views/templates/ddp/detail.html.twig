{% extends "baseTemplate.html.twig" %}

{% block title %}
	Détails d’une demande de paiement
{% endblock %}

{% block stylesheets %}
	<link href="{{ App.base_path }}/Views/css/new.css?v=2025.10.22.08.00" rel="stylesheet"/>
	<link href="{{ App.base_path }}/Views/css/da/style.css?v=2025.10.22.08.00" rel="stylesheet"/>
	<link href="{{ App.base_path }}/Views/css/da/detail.css?v=2025.10.22.08.00" rel="stylesheet"/>
{% endblock %}

{% import "macroForm.html.twig" as macroForm %}

{% block overlay %}
	{% include "/shared/_overlay.html.twig"  %}
{% endblock %}

{% block content %}
	<div class="container-spaced mt-6">
		<nav>
			<div class="onglet-head nav nav-tabs" id="nav-tab" role="tablist">
				<button class="nav-link active" id="nav-detail-tab" data-bs-toggle="tab" data-bs-target="#nav-detail" type="button" role="tab" aria-controls="nav-detail" aria-selected="true">Détail</button>
				<button class="nav-link" id="nav-document-rattache-tab" data-bs-toggle="tab" data-bs-target="#nav-document-rattache" type="button" role="tab" aria-controls="nav-document-rattache" aria-selected="false">Documents rattachés</button>
			</div>
		</nav>
		<div class="card border-top-left-radius-0">
			<div class="card-body">
				<div class="container-fluid">
					<div class="tab-content" id="nav-tabContent">
						<div class="tab-pane fade active show" id="nav-detail" role="tabpanel" aria-labelledby="nav-detail-tab">
							{{ include('ddp/shared/_detail.html.twig') }}
						</div>
						<div class="tab-pane fade" id="nav-document-rattache" role="tabpanel" aria-labelledby="nav-document-rattache-tab">
							{{ include('da/shared/detail/document-rattache.html.twig') }}
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

{% block javascript %}
	<script src="{{ App.base_path }}/Views/js/da/detail/document-rattache.js?v=2025.10.22.08.00" type="module"></script>
{% endblock %}
