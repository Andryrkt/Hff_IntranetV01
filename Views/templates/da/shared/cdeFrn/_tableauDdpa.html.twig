<h6 class="fw-bold fs-6">{{dto.titreDaDdpa}}</h6>
<table class="table">
	<thead class="table-dark align-middle">
		<tr>
			<th class="text-center">Numéro</th>
			<th class="text-center">Date</th>
			<th>Motif</th>
			<th class="text-center">Montant HT</th>
			<th class="text-center">%</th>
			<th class="text-center">% Cumul</th>
			<th class="text-center">Statut</th>
		</tr>
	</thead>
	<tbody>
		{% for item in dto.daDdpa %}
			<tr>
				<td class="text-center">{{item.numeroDdp}}</td>
				<td class="text-center">{{item.datecreation|date('d/m/Y')}}</td>
				<td>{{item.motif}}</td>
				<td class="text-end">{{item.montant|number_format(2,',','.')}}</td>
				<td class="text-end">{{item.ratio|round(2)|number_format(2,',','.')}}%</td>
				<td class="text-end">{{item.cumul|round(2)|number_format(2,',','.')}}%</td>
				<td class="text-center">{{item.statut}}</td>
			</tr>
		{% else %}
			<tr>
				<td colspan="6" class="text-center">Aucune donnée disponible</td>
			</tr>
		{% endfor %}
		<tr>
			<td colspan="6"></td>
		</tr>
		<tr>
			<td class="fw-bold">Total payé / encours</td>
			<td colspan="2"></td>
			<td class="text-end fw-bold">{{dto.totalPayer|number_format(2,',','.')}}</td>
			<td class="text-end fw-bold">{{dto.ratioTotalPayer|round(2)|number_format(2,',','.')}}%</td>
			<td></td>
		</tr>
		<tr>
			<td colspan="6"></td>
		</tr>
		<tr>
			<td class="fw-bold">Montant à régulariser</td>
			<td colspan="2"></td>
			<td class="text-end text-danger fw-bold">{{dto.montantAregulariser|number_format(2,',','.')}}</td>
			<td class="text-end text-danger fw-bold">{{dto.ratioMontantARegul|round(2)|number_format(2,',','.')}}%</td>
			<td></td>
		</tr>
	</tbody>
</table>
