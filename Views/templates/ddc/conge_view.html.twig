{% extends "baseTemplate.html.twig" %}

{% block title %}
	{{ title }}
{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ webpack_asset('listConge.css') }}">
{% endblock %}

{% block content %}
	<div class="container-spaced">

		{% include "/ddc/shared/_formulaireRechercheConge.html.twig" with {'form': form} %}
		{% include "/ddc/shared/_pagination_conge.html.twig" with {'viewMode': viewMode} %}

		<div id="view-container">
			{% if viewMode == 'calendar' %}
				{% include "/ddc/_calendar_content.html.twig" %}
			{% else %}
				{% include "/ddc/_list_content.html.twig" %}
			{% endif %}
		</div>
	</div>

	<!-- MODAL DETAILS -->
	<div class="modal fade" id="congeDetailsModal" tabindex="-1" aria-hidden="true">
		<div class="modal-dialog">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title">Détails de la demande de congé</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
				</div>
				<div class="modal-body" id="congeDetailsContent"></div>
				<div class="modal-footer">
					<button class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

{% block javascript %}
	<script>
		// Injection forcée et sécurisée des données
(function () {
window.pageData = {{ (data|default([]))|json_encode|raw }};
window.congesData = {{ (conges|default([]))|json_encode|raw }};
window.employeesData = {{ (employees|default({}))|json_encode|raw }};
window.forcedViewMode = "{{ viewMode|default('list') }}";{% if selected_month %}
window.selectedMonth = "{{ selected_month|date('Y-m-d') }}";{% endif %}

// Forçage immédiat du DOM
document.body.setAttribute('data-view-mode', window.forcedViewMode);
document.body.setAttribute('data-type-view', window.forcedViewMode);

console.log("DDC Template: Données injectées", {
mode: window.forcedViewMode,
empCount: Object.keys(window.employeesData).length
});
})();
	</script>

	<!-- Templates pour le rendu dynamique JS -->
	<script type="text/template" id="list-template">
		{% include "/ddc/_list_content.html.twig" %}
	</script>
	<script type="text/template" id="calendar-template">
		{% include "/ddc/_calendar_content.html.twig" %}
	</script>

	<script src="{{ webpack_asset('listConge.js') }}" defer></script>
{% endblock %}
